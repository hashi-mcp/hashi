{
  "name": "hashi-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Hashi — make professional desktop apps speak Claude.",
  "type": "module",
  "license": "MIT",
  "author": "Alexandre Parena <contact.parena@gmail.com>",
  "homepage": "https://github.com/hashi-mcp/hashi",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hashi-mcp/hashi.git"
  },
  "bugs": {
    "url": "https://github.com/hashi-mcp/hashi/issues"
  },
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "pnpm -r --if-present typecheck",
    "clean": "pnpm -r --if-present clean && rm -rf node_modules",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/cli": "^2.27.10",
    "@types/node": "^20.17.10",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
