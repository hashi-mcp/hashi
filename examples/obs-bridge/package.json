{
  "name": "@hashi-mcp/example-obs-bridge",
  "version": "0.0.1",
  "private": true,
  "description": "Example Hashi bridge for OBS Studio via the obs-websocket plugin.",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "hashi-obs-bridge": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo",
    "start": "node dist/index.js"
  },
  "license": "MIT",
  "author": "Alexandre Parena <contact.parena@gmail.com>",
  "dependencies": {
    "@hashi-mcp/core": "workspace:^",
    "@hashi-mcp/server": "workspace:^",
    "obs-websocket-js": "^5.0.6"
  },
  "engines": {
    "node": ">=20"
  }
}
